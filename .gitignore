# ============================================================
# Visual Studio C++ 项目忽略配置
# ============================================================

# 编译输出目录
x64/
x86/
Debug/
Release/
out/
bin/
obj/

# Visual Studio 用户特定文件
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio 缓存/临时文件
*.vspscc
*.vssscc
.builds
*.pidb
*.log
*.scc

# Visual Studio 性能分析文件
*.psess
*.vsp
*.vspx

# 编译生成的文件
*.dll
*.exe
*.lib
*.pdb
*.ilk
*.obj
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.idb
*.ipch
*.iobj
*.ipdb
*.pgc
*.pgd

# 预编译头缓存
*.pch
*.gch

# 资源文件
*.res
*.rc
*.rc2

# 中间文件
*.exp
*.map
*.manifest

# NuGet 包
packages/
*.nupkg

